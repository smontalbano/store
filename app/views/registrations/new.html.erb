<h1>Create an Account</h1>

<%= form_with model: @user, url: registration_path do |form| %>
    <% if @user.errors.any? %>
        <div style="color: red">
            <h2><%= pluralize(@user.errors.count, "error") %></h2>
            <ul>
                <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                <% end %>
            </ul>
        </div>
    <% end %>

    <div>
        <%= form.label :email_address %>
        <%= form.email_field :email_address, required: true, autofocus: true %>
    </div>

    <div>
        <%= form.label :password %>
        <%= form.password_field :password, required: true %>
    </div>

    <div>
        <%= form.label :password_confirmation %>
        <%= form.password_field :password_confirmation, required: true %>
    </div>

    <div>
        <%= form.submit "Register" %>
    </div>

<% end %>

<button><%= link_to "Already have an account? Sign In", new_session_path %></button>